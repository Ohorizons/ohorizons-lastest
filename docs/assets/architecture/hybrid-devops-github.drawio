#DCE0E5;strokeWidth=1.5;align=left;verticalAlign=top;spacing=10;spacingLeft=16;fontSize=10;arcSize=8;" vertex="1" parent="1"><mxGeometry x="455" y="1452" width="310" height="82" as="geometry" /></mxCell><mxCell id="hy-2_bar" value="" style="rounded=0;fillColor=#0078D4;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="455" y="1452" width="6" height="82" as="geometry" /></mxCell><mxCell id="hy-3" value="&lt;b style=&quot;font-size:12px;color:#24292F&quot;&gt;3. Scaffold&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;color:#5E636B&quot;&gt;Templates publish to GitHub or Azure Repos&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#DCE0E5;strokeWidth=1.5;align=left;verticalAlign=top;spacing=10;spacingLeft=16;fontSize=10;arcSize=8;" vertex="1" parent="1"><mxGeometry x="800" y="1452" width="310" height="82" as="geometry" /></mxCell><mxCell id="hy-3_bar" value="" style="rounded=0;fillColor=#7FBA00;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="800" y="1452" width="6" height="82" as="geometry" /></mxCell><mxCell id="hy-4" value="&lt;b style=&quot;font-size:12px;color:#24292F&quot;&gt;4. Build&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;color:#5E636B&quot;&gt;Actions or Azure Pipelines build and scan&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#DCE0E5;strokeWidth=1.5;align=left;verticalAlign=top;spacing=10;spacingLeft=16;fontSize=10;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1145" y="1452" width="310" height="82" as="geometry" /></mxCell><mxCell id="hy-4_bar" value="" style="rounded=0;fillColor=#24292F;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="1145" y="1452" width="6" height="82" as="geometry" /></mxCell><mxCell id="hy-5" value="&lt;b style=&quot;font-size:12px;color:#24292F&quot;&gt;5. Package&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;color:#5E636B&quot;&gt;Images land in GHCR or ACR&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html