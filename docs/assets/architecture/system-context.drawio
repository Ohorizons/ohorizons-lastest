"110" as="geometry" /></mxCell><mxCell id="identity_icon" value="" style="shape=image;html=1;imageAspect=1;aspect=fixed;image=data:image/svg+xml;base64,;" vertex="1" parent="1"><mxGeometry x="940" y="1210" width="34" height="34" as="geometry" /></mxCell><mxCell id="security" value="&lt;b style=&quot;color:#24292F;font-size:14px&quot;&gt;Security and telemetry&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#5E636B;font-size:11px;line-height:1.35&quot;&gt;Defender, Purview, Policy&lt;br&gt;Application Insights and logs&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E8EBEF;strokeWidth=1.5;align=left;verticalAlign=top;spacing=12;spacingLeft=18;fontSize=11;fontColor=#24292F;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1030" y="1192" width="420" height="110" as="geometry" /></mxCell><mxCell id="security_accent" value="" style="rounded=0;fillColor=#F25022;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="1030" y="1192" width="6" height="110" as="geometry" /></mxCell><mxCell id="security_icon" value="" style="shape=image;html=1;imageAspect=1;aspect=fixed;image=data:image/svg+xml;base64,;" vertex="1" parent="1"><mxGeometry x="1400" y="1210" width="34" height="34" as="geometry" /></mxCell><mxCell id="context-note" value="&lt;b style=&quot;color:#24292F;font-size:14px&quot;&gt;How to use this view&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#5E636B;font-size:11px;line-height:1.35&quot;&gt;Read left to right by plane&lt;br&gt;Use detail diagrams for internal flows&lt;br&gt;No hidden public data paths&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E8EBEF;strokeWidth=1.5;align=left;verticalAlign=top;spacing=12;spacingLeft=18;fontSize=11;fontColor=#24292F;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1570" y="428" width="760" height="354" as="geometry" /></mxCell><mxCell id="context-note_accent" value="" style="rounded=0;fillColor=#0078D4;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="1570" y="428" width="6" height="354" as="geometry" /></mxCell><mxCell id="review-note" value="&lt;b style=&quot;color:#24292F;font-size:14px&quot;&gt;Review questions&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#5E636B;font-size:11px;line-height:1.35&quot;&gt;Which hybrid scenario is default?&lt;br&gt;Which SLO and DR targets apply?&lt;br&gt;Which agent budgets are approved?&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E8EBEF;strokeWidth=1.5;align=left;verticalAlign=top;spacing=12;spacingLeft=18;fontSize=11;fontColor=#24292F;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1570" y="932" width="760" height="370" as="geometry" /></mxCell><mxCell id="review-note_accent" value="" style="rounded=0;fillColor=#FFB900;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="1570" y="932" width="6" height="370" as="geometry" /></mxCell><mxCell id="flow-user" value="&lt;b style=&quot;font-size:12px;color:#24292F&quot;&gt;1. User request&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;color:#5E636B&quot;&gt;Developer uses Backstage or GitHub Copilot&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#DCE0E5;strokeWidth=1.5;align=left;verticalAlign=top;spacing=10;spacingLeft=16;fontSize=10;arcSize=8;" vertex="1" parent="1"><mxGeometry x="110" y="1432" width="300" height="82" as="geometry" /></mxCell><mxCell id="flow-user_bar" value="" style="rounded=0;fillColor=#24292F;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="110" y="1432" width="6" height="82" as="geometry" /></mxCell><mxCell id="flow-source" value="&lt;b style=&quot;font-size:12px;color:#24292F&quot;&gt;2. Source event&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;color:#5E636B&quot;&gt;GitHub or Azure DevOps triggers CI/CD&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#DCE0E5;strokeWidth=1.5;align=left;verticalAlign=top;spacing=10;spacingLeft=16;fontSize=10;arcSize=8;" vertex="1" parent="1"><mxGeometry x="450" y="1432" width="300" height="82" as="geometry" /></mxCell><mxCell id="flow-source_bar" value="" style="rounded=0;fillColor=#0078D4;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="450" y="1432" width="6" height="82" as="geometry" /></mxCell><mxCell id="flow-deploy" value="&lt;b style=&quot;font-size:12px;color:#24292F&quot;&gt;3. GitOps deploy&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;color:#5E636B&quot;&gt;ArgoCD reconciles manifests to AKS&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#DCE0E5;strokeWidth=1.5;align=left;verticalAlign=top;spacing=10;spacingLeft=16;fontSize=10;arcSize=8;" vertex="1" parent="1"><mxGeometry x="790" y="1432" width="300" height="82" as="geometry" /></mxCell><mxCell id="flow-deploy_bar" value="" style="rounded=0;fillColor=#F25022;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="790" y="1432" width="6" height="82" as="geometry" /></mxCell><mxCell id="flow-ai" value="&lt;b style=&quot;font-size:12px;color:#24292F&quot;&gt;4. Agent call&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;color:#5E636B&quot;&gt;Backstage plugin calls Agent API&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#DCE0E5;strokeWidth=1.5;align=left;verticalAlign=top;spacing=10;spacingLeft=16;fontSize=10;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1130" y="1432" width="300" height="82" as="geometry" /></mxCell><mxCell id="flow-ai_bar" value="" style="rounded=0;fillColor=#F25022;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="1130" y="1432" width="6" height="82" as="geometry" /></mxCell><mxCell id="flow-foundry" value="&lt;b style=&quot;font-size:12px;color:#24292F&quot;&gt;5. Inference and context&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;color:#5E636B&quot;&gt;Foundry, Redis, and AI Search respond&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#DCE0E5;strokeWidth=1.5;align=left;verticalAlign=top;spacing=10;spacingLeft=16;fontSize=10;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1470" y="1432" width="300" height="82" as="geometry" /></mxCell><mxCell id="flow-foundry_bar" value="" style="rounded=0;fillColor=#00A4EF;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="1470" y="1432" width="6" height="82" as="geometry" /></mxCell><mxCell id="flow-govern" value="&lt;b style=&quot;font-size:12px;color:#24292F&quot;&gt;6. Telemetry and governance&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;color:#5E636B&quot;&gt;Logs, cost, trajectory, policy and audit&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#DCE0E5;strokeWidth=1.5;align=left;verticalAlign=top;spacing=10;spacingLeft=16;fontSize=10;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1810" y="1432" width="360" height="82" as="geometry" /></mxCell><mxCell id="flow-govern_bar" value="" style="rounded=0;fillColor=#7FBA00;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="1810" y="1432" width="6" height="82" as="geometry" /></mxCell><mxCell id="edge_0" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#969CA4;strokeWidth=2;endArrow=block;fontSize=11;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="422" y="1473" as="sourcePoint" /><mxPoint x="438" y="1473" as="targetPoint" /><Array as="points"></Array></mxGeometry></mxCell><mxCell id="edge_1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#969CA4;strokeWidth=2;endArrow=block;fontSize=11;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="762" y="1473" as="sourcePoint" /><mxPoint x="778" y="1473" as="targetPoint" /><Array as="points"></Array></mxGeometry></mxCell><mxCell id="edge_2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#969CA4;strokeWidth=2;endArrow=block;fontSize=11;fontSt