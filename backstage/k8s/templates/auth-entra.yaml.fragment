    auth:
      environment: production
      providers:
        microsoft:
          production:
            clientId: ${ENTRA_CLIENT_ID}
            clientSecret: ${ENTRA_CLIENT_SECRET}
            tenantId: ${ENTRA_TENANT_ID}
            signIn:
              resolvers:
                - resolver: emailMatchingUserEntityProfileEmail
                  dangerouslyAllowSignInWithoutUserInCatalog: true
